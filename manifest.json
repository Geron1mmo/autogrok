{
  "manifest_version": 3,
  "name": "AutoGrok Team Pro v6.0 Human-Grok",
  "version": "6.0.0",
  "description": "AutoGrok v6.0 — automated Grok workflows with human-in-the-loop confirmation.",
  "permissions": [
    "storage",
    "downloads",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://grok.com/*",
    "https://x.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://grok.com/*",
        "https://x.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "grok-ws-bridge.js"
      ],
      "matches": [
        "https://grok.com/*",
        "https://x.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "AutoGrok Team Pro v6.0",
    "default_popup": "popup.html"
  }
}